---
import Layout from '../layouts/Layout.astro';

const jobs = [
  {
    company: "Netflix",
    role: "Product Strategy Manager",
    dates: "2025 – present",
    location: "San Francisco, CA",
    bullets: [
      "Leading product strategy for GenAI initiatives applied to content production, working at the intersection of AI research and editorial workflows.",
    ],
  },
  {
    company: "Ramp",
    role: "Senior Product Operations Manager",
    dates: "2024 – 2025",
    location: "New York, NY",
    bullets: [
      "Product Strategy: Led initiative targeting enterprise IT personas to expedite adoption among large enterprises, hitting spend milestones 20% faster and mitigating $5M in fraudulent account takeovers.",
      "Release Management: Led platform migration across 10+ engineering teams to support new compliance workflows, then owned sales enablement to ensure a successful launch.",
      "Data Analysis: Conducted root cause analysis on customer support tickets and shipped in-app self-service workflows, reducing support ticket volume by 20% MoM.",
    ],
  },
  {
    company: "General Catalyst",
    role: "Venture Capital MBA Intern",
    dates: "Spring 2024",
    location: "Boston, MA",
    intern: true,
    bullets: [
      "Published research on enterprise Generative AI adoption based on 20+ interviews with tech leaders and enterprise buyers, under Partner Deep Nishar.",
    ],
  },
  {
    company: "SpaceX — Starlink",
    role: "Business Operations MBA Intern",
    dates: "Summer 2023",
    location: "Los Angeles, CA",
    intern: true,
    bullets: [
      "GTM Strategy: Redesigned go-to-market strategy for the Starlink Business offering by prioritizing the top three segments by NPS and market size, identifying target customers, and selecting optimal channels.",
      "New Market Launch: Built India market entry plan through prospective user interviews, expert research, and SQL-based pricing analysis of historical usage and customer feedback.",
      "A/B Experimentation: Led testing to identify churn drivers among travel plan customers; applied segmentation by price sensitivity and purchasing behavior to improve retention.",
    ],
  },
  {
    company: "Warp",
    role: "Product Manager Pre-MBA Intern",
    dates: "Summer 2022",
    location: "New York, NY",
    intern: true,
    bullets: [
      "Roadmap Ownership: Established the company's first sprint planning program to systematically prioritize a backlog of 300+ feature requests, contributing to a 30% increase in cohort retention.",
      "Operational Efficiency: Built automations that cut the engineering team's bug resolution SLA by 60%.",
    ],
  },
  {
    company: "LinkedIn",
    role: "Product Operations Manager",
    dates: "2020 – 2022",
    location: "San Francisco, CA",
    bullets: [
      "Large-Scale Launch: Led strategy to onboard the largest business unit ($6B revenue) to a new sales platform, resulting in a 30% revenue increase with VP approval.",
      "Cross-Functional Collaboration: Negotiated a phased launch of a joint sales model with Microsoft ($400M forecast), working with the COO and MSFT leadership to accelerate timeline without deprioritizing other workstreams.",
      "Honors: President's Club Award — top 5% of performers globally.",
    ],
  },
  {
    company: "Adobe",
    role: "Solutions Engineer",
    dates: "2017 – 2020",
    location: "San Francisco, CA",
    bullets: [
      "Product Impact: Proactively identified an API gap affecting 30% of clients, built the MVP for a fix, and partnered with product management to drive it into the full roadmap.",
      "Client Impact: Led a retail client engagement yielding $1.2M in marketing savings and $200K in incremental revenue.",
      "Honors: 2× Sales Achievement Award (top 10% by quota); Adobe Insider Conference Tour Speaker.",
    ],
  },
];
---

<Layout title="Experience">
  <div class="experience">
    <h2>Experience</h2>

    <ul>
      {jobs.map((job) => (
        <li>
          <div class="header">
            <span class="company">{job.company}</span>
            {job.intern && <span class="tag">internship</span>}
          </div>
          <div class="meta">
            <span class="role">{job.role}</span>
            <span class="dates">{job.dates} · {job.location}</span>
          </div>
          <ul class="bullets">
            {job.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .experience {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 500;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .company {
    font-size: 1.05rem;
    font-weight: 500;
    color: #1e3a5f;
  }

  .tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #8a8077;
    border: 1px solid #d6cfc6;
    border-radius: 3px;
    padding: 1px 6px;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .role {
    font-size: 0.95rem;
    color: #2c2a27;
  }

  .dates {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #8a8077;
  }

  .bullets {
    margin-top: 8px;
    list-style: disc;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .bullets li {
    font-size: 0.93rem;
    color: #4a4640;
    line-height: 1.65;
  }
</style>
