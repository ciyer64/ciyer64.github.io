---
import Layout from '../layouts/Layout.astro';

const jobs = [
  {
    company: "Netflix",
    role: "Product Strategy",
    dates: "2025 – present",
    location: "San Francisco, CA",
    blurbHtml: `Advising senior engineering, product, and content leadership on GenAI strategy for content production, spanning first-party workflows and third-party vendor solutions. Contributed to Netflix's acquisition of <a href="https://about.netflix.com/en/news/why-interpositive-is-joining-netflix" target="_blank" rel="noopener">InterPositive</a>, a studio technology company co-founded by Ben Affleck.`,
  },
  {
    company: "Ramp",
    role: "Senior Product Operations Manager",
    dates: "2024 – 2025",
    location: "New York, NY",
    blurbHtml: `Generalist role on Ramp's identity and enterprise platform pod, spanning product, data science, and marketing. Expanded access to the IT admin role across all customer plans after identifying it reduced fraudulent account takeover risk and accelerated spend milestones by 20%. Led user research and GTM for the launch of <a href="https://ramp.com/blog/governance-that-runs-itself" target="_blank" rel="noopener">custom roles and permissions</a> for enterprise compliance, requiring a permissions framework migration across 10+ engineering teams. Shipped in-app self-service workflows from support ticket root cause analysis, meaningfully reducing support ticket volume. Served as product SME for monthly NPS reporting, building GenAI-based summaries using the GPT and Claude APIs to surface root causes of monthly variance.`,
  },
  {
    company: "General Catalyst",
    role: "Venture Capital MBA Intern",
    dates: "Spring 2024",
    location: "Boston, MA",
    blurbHtml: `Published a research report on enterprise GenAI adoption in partnership with <a href="https://www.generalcatalyst.com/stories/welcome-deep-nishar-to-general-catalyst" target="_blank" rel="noopener">Deep Nishar</a>, based on interviews with 20+ software leaders and enterprise buyers. <a href="https://medium.com/@curren.iyer/gen-ai-the-open-source-opportunity-c23bc63f5ae5" target="_blank" rel="noopener">Read the report here.</a>`,
  },
  {
    company: "SpaceX — Starlink",
    role: "Business Operations MBA Intern",
    dates: "Summer 2023",
    location: "Los Angeles, CA",
    blurb: "MBA intern on the Product Growth team within Starlink Business Operations. Redesigned the GTM strategy for Starlink Business by prioritizing top segments by NPS and market size, selecting target customers and optimal channels. Proposed a new market entry plan for India and Africa through user interviews, expert research, and SQL-based pricing analysis.",
  },
  {
    company: "Warp",
    role: "Product Manager Pre-MBA Intern",
    dates: "Summer 2022",
    location: "New York, NY",
    blurb: "First product hire at a Sequoia-backed devtools startup. Established the company's first sprint planning program to prioritize a backlog of 300+ feature requests, contributing to improved cohort retention. Built automations that cut the engineering team's bug resolution SLA by 60%.",
  },
  {
    company: "LinkedIn",
    role: "Senior Associate, Product Operations",
    dates: "2020 – 2022",
    location: "San Francisco, CA",
    blurb: "Owned the CRM, quoting, and billing platforms powering LinkedIn's sales org. Built platform support to launch a co-sell between the Talent and Learning business units, contributing to LinkedIn crossing $10B in revenue in FY2021. Navigated a last-minute request from sales and Microsoft leadership to ship a $XXXM joint sales motion, launching an MVP without deprioritizing existing commitments. Led the migration strategy for LinkedIn's Talent business unit to the new CRM platform. President's Club Award — top 5% of performers globally.",
  },
  {
    company: "Adobe",
    role: "Solutions Engineer",
    dates: "2017 – 2020",
    location: "San Francisco, CA",
    blurb: "Proactively identified an API gap affecting 30% of clients, built the MVP, and partnered with product to drive it into the full roadmap. 2× Sales Achievement Award winner (top 10% by quota) and Adobe Insider Conference Tour Speaker.",
  },
];
---

<Layout title="Experience">
  <div class="experience">
    <h2>Experience</h2>

    <ul>
      {jobs.map((job) => (
        <li>
          <div class="job-header">
            <div class="job-meta">
              <span class="company">{job.company}</span>
              <span class="role">{job.role}</span>
            </div>
            <div class="job-right">
              <span class="dates">{job.dates}</span>
              <span class="location">{job.location}</span>
            </div>
          </div>
          {job.blurbHtml
            ? <p class="blurb" set:html={job.blurbHtml} />
            : <p class="blurb">{job.blurb}</p>
          }
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .experience {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 500;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  li {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .job-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .company {
    font-size: 1.05rem;
    font-weight: 500;
    color: #1e3a5f;
  }

  .role {
    font-size: 0.95rem;
    color: #2c2a27;
  }

  .location {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #8a8077;
  }

  .job-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }

  .dates {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #8a8077;
    white-space: nowrap;
  }

  .blurb {
    margin-top: 8px;
    font-size: 0.93rem;
    color: #4a4640;
    line-height: 1.75;
  }

  @media (max-width: 600px) {
    .job-header {
      flex-direction: column-reverse;
      gap: 2px;
    }
  }
</style>
